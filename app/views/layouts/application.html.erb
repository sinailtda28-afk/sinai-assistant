<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Sinai Assistant" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <% if Rails.env.production? %>
      <%= javascript_importmap_tags %>
    <% else %>
      <script type="importmap" data-turbo-track="reload">{"imports":{"application":"/assets/application.js","@hotwired/stimulus":"/assets/vendor/stimulus.js","@hotwired/stimulus-loading":"/assets/vendor/stimulus-loading.js","controllers/application":"/assets/controllers/application.js","controllers/kanban_controller":"/assets/controllers/kanban_controller.js","controllers/calendar_controller":"/assets/controllers/calendar_controller.js","controllers/column_settings_controller":"/assets/controllers/column_settings_controller.js","controllers/filter_controller":"/assets/controllers/filter_controller.js","controllers/inline_edit_controller":"/assets/controllers/inline_edit_controller.js","controllers/modal_controller":"/assets/controllers/modal_controller.js","controllers/task_form_controller":"/assets/controllers/task_form_controller.js","controllers/hello_controller":"/assets/controllers/hello_controller.js","sortablejs":"/assets/vendor/sortablejs.js","chartkick":"/assets/vendor/chartkick.js","Chart.bundle":"/assets/vendor/chart.js"}}</script>
      <script type="module">import "application"</script>
    <% end %>
  </head>
  <body>
    <nav>
      <a href="/" class="app-name">Sinai</a>
      <a href="/">Kanban</a>
      <a href="/dashboard">Dashboard</a>
      <a href="/calendar">Calendario</a>
      <a href="/history">Historico</a>
      <a href="/settings">Config</a>
      <button class="theme-toggle" onclick="
        const body = document.body;
        if (body.classList.contains('dark')) { body.classList.remove('dark'); body.classList.add('glass'); localStorage.setItem('theme','glass'); }
        else if (body.classList.contains('glass')) { body.classList.remove('glass'); localStorage.setItem('theme','light'); }
        else { body.classList.add('dark'); localStorage.setItem('theme','dark'); }
        this.innerHTML = body.classList.contains('dark') ? '&#9790;' : body.classList.contains('glass') ? '&#9830;' : '&#9788;'
      ">&#9788;</button>
    </nav>
    <script>
      (function() {
        const theme = localStorage.getItem('theme')
        if (theme === 'dark') document.body.classList.add('dark')
        else if (theme === 'glass') document.body.classList.add('glass')
        const btn = document.querySelector('.theme-toggle')
        if (btn) btn.innerHTML = theme === 'dark' ? '&#9790;' : theme === 'glass' ? '&#9830;' : '&#9788;'
      })()
    </script>
    <main class="container">
      <%= yield %>
    </main>
  </body>
</html>
