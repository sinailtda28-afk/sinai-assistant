<h1>Calendário</h1>
<div class="calendar-nav">
  <%= link_to "← Mês anterior", calendar_path(date: (@date - 1.month).beginning_of_month), class: "btn btn-secondary" %>
  <h2><%= @date.strftime("%B %Y") %></h2>
  <%= link_to "Próximo mês →", calendar_path(date: (@date + 1.month).beginning_of_month), class: "btn btn-secondary" %>
</div>

<table class="calendar-table">
  <thead>
    <tr>
      <th>Dom</th><th>Seg</th><th>Ter</th><th>Qua</th><th>Qui</th><th>Sex</th><th>Sáb</th>
    </tr>
  </thead>
  <tbody>
    <% (@start_date..@end_date).each_slice(7) do |week| %>
      <tr>
        <% week.each do |day| %>
          <td class="<%= "other-month" if day.month != @date.month %><%= " today" if day == Date.current %>">
            <div class="calendar-day">
              <%= link_to day.day, calendar_day_path(date: day), class: "day-link" %>
            </div>
            <% @tasks.select { |t| t.due_date&.to_date == day }.each do |task| %>
              <div class="calendar-event priority-<%= task.priority %>">
                <%= task.title %>
              </div>
            <% end %>
          </td>
        <% end %>
      </tr>
    <% end %>
  </tbody>
</table>
