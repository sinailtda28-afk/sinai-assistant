<h1><%= l(@date, format: :long) %></h1>
<%= link_to "← Voltar ao calendário", calendar_path(date: @date), class: "back-link" %>

<div class="dash-card" style="margin:1rem 0">
  <h3>Nova Tarefa</h3>
  <%= form_with model: Task.new, url: tasks_path, method: :post, html: { style: "display:flex;gap:0.5rem;align-items:flex-end;flex-wrap:wrap" } do |f| %>
    <div class="form-group" style="flex:1;min-width:200px">
      <%= f.text_field :title, placeholder: "Titulo da tarefa", required: true, style: "width:100%;padding:0.4rem;border:1px solid #d1d5db;border-radius:5px;background:var(--card-bg);color:var(--text)" %>
    </div>
    <div class="form-group">
      <%= f.select :priority, [["Baixa","low"],["Media","medium"],["Alta","high"]], { selected: "medium" }, style: "padding:0.4rem;border:1px solid #d1d5db;border-radius:5px;background:var(--card-bg);color:var(--text)" %>
    </div>
    <%= f.hidden_field :due_date, value: @date.iso8601 %>
    <%= f.hidden_field :column_id, value: @column&.id %>
    <div class="form-group">
      <%= f.submit "Criar", class: "btn btn-primary btn-sm" %>
    </div>
  <% end %>
</div>

<% if @tasks.any? %>
  <div class="day-tasks">
    <% @tasks.each do |task| %>
      <div class="task-card">
        <strong><%= task.title %></strong>
        <% if task.description.present? %>
          <div style="font-size:0.8rem;color:var(--text-secondary);margin-top:2px"><%= truncate(task.description, length: 100) %></div>
        <% end %>
        <div class="task-meta">
          <span class="priority-chip priority-<%= task.priority %>"><%= { "low" => "Baixa", "medium" => "Media", "high" => "Alta" }[task.priority] %></span>
          <%= task.due_date.strftime("%H:%M") if task.due_date %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p style="color:var(--text-secondary);font-style:italic">Nenhuma tarefa para este dia.</p>
<% end %>
